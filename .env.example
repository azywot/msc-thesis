# ==============================================================================
# Environment Variables for MSC Thesis Project
# ==============================================================================

# ==============================================================================
# API Keys (Required for most experiments)
# ==============================================================================

# Serper API (required for web search tool)
# Get your key from: https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# OpenAI API (optional, only needed if using GPT models)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (optional, only needed if using Claude models)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# HuggingFace token (required for gated datasets: GAIA, GPQA)
# Get your token from: https://huggingface.co/settings/tokens
# After generating, accept terms at:
#   https://huggingface.co/datasets/gaia-benchmark/GAIA
#   https://huggingface.co/datasets/Idavidrein/gpqa
#   https://huggingface.co/datasets/cais/hle
HF_TOKEN=your_hf_token_here
# hf_cache.env
HF_HOME=your_hf_home_here
HF_HUB_CACHE=your_hf_hub_cache_here

# Optional: Jina API for web page extraction (not currently used)
# JINA_API_KEY=your_jina_api_key_here

# ==============================================================================
# Weights & Biases (Optional, for experiment tracking)
# ==============================================================================

# W&B API key (optional, for logging experiments)
# Get your key from: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# W&B project name (default: msc-thesis)
WANDB_PROJECT=msc-thesis

# W&B entity (optional, your username or team name)
# WANDB_ENTITY=your_username

# ==============================================================================
# Reproducibility
# ==============================================================================

# Python hash seed for reproducible results
PYTHONHASHSEED=0

# ==============================================================================
# HPC / Project Configuration (Optional, read by job scripts and submit_job.sh)
# ==============================================================================

# Project directory; jobs cd into this directory. submit_job.sh passes it to sbatch.
PROJECT_DIR=/path/to/msc-thesis

# Conda environment name for setup, experiments, and dataset jobs
ENV_NAME=agent_engine

# Data directory for datasets (default: /scratch-shared/$USER/data)
# DATA_DIR=/scratch-shared/$USER/data

# ==============================================================================
# Usage Instructions
# ==============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env with your actual API keys:
#    nano .env  # or vim, emacs, etc.
#
# 3. The .env file is automatically loaded by:
#    - Job scripts (001_setup.job, 002_download_datasets.job, etc.)
#    - Experiment runner (scripts/run_experiment.py)
#
# 4. Never commit .env to git (it's in .gitignore)
#
# ==============================================================================
