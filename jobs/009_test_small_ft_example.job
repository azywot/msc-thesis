#!/bin/bash
#SBATCH --job-name=SmokeFT
#SBATCH --partition=gpu_a100
#SBATCH --gpus=4
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --time=02:00:00
#SBATCH --output=out/fine_tuning/smoke_%A.log
#SBATCH --error=out/fine_tuning/smoke_%A.err

# Smoke-test the fine-tuning pipeline end-to-end:
#   1. Pre-flight checks (no GPU): imports, reward, config, parquet schema
#   2. One epoch of GRPO training on 16 questions with config_smoke.yaml
#   3. Verify checkpoint was written and W&B run exists
#
# Run AFTER job 008 (creates cosmas-train + data — must already be prepared).
# If this passes, the full training job (010) is safe to submit.

set -euo pipefail

echo "=========================================="
echo "MSC Thesis — Fine-Tuning Smoke Test"
echo "=========================================="
echo "Start time: $(date)"
echo "Job ID: ${SLURM_JOB_ID:-local}  Node: $(hostname)"
echo ""

module purge
module load 2025
module load Miniconda3/25.5.1-1
module load CUDA/12.8.0
module load cuDNN/9.10.1.4-CUDA-12.8.0

PROJECT_DIR="${PROJECT_DIR:-$HOME/azywot/msc-thesis}"
cd "$PROJECT_DIR" || exit 1
echo "Project directory: $PROJECT_DIR"

if [[ -f ".env" ]]; then
    echo "Loading environment variables from .env..."
    set -a
    source <(grep -v '^#' .env | grep -v '^$' | grep -v '^[[:space:]]*#')
    set +a
fi

if [[ -z "${SERPER_API_KEY:-}" && -z "${TAVILY_API_KEY:-}" ]]; then
    echo "ERROR: SERPER_API_KEY or TAVILY_API_KEY must be set for rollout workers."
    exit 1
fi

if [[ -z "${WANDB_API_KEY:-}" ]]; then
    echo "Warning: WANDB_API_KEY is not set; W&B logging may fail."
fi

# cosmas-train is created once by jobs/008_prepare_fine_tuning_data.job.
if ! conda env list | awk '{print $1}' | grep -qx "cosmas-train"; then
    echo "ERROR: conda env 'cosmas-train' not found."
    echo "Run jobs/008_prepare_fine_tuning_data.job first (creates env + training data)."
    exit 1
fi

source activate cosmas-train
export PYTHONNOUSERSITE=1

AGENTFLOW_ROOT="${AGENTFLOW_ROOT:-$HOME/azywot/AgentFlow}"
AGENTFLOW_REPO="${AGENTFLOW_REPO:-https://github.com/shin-ee-chen/AgentFlow.git}"
if [[ ! -d "$AGENTFLOW_ROOT/agentflow" ]]; then
    echo "AgentFlow clone not found at $AGENTFLOW_ROOT; cloning..."
    if [[ -e "$AGENTFLOW_ROOT" ]]; then
        echo "ERROR: $AGENTFLOW_ROOT exists but does not contain an agentflow/ package."
        exit 1
    fi
    git clone "$AGENTFLOW_REPO" "$AGENTFLOW_ROOT"
fi

echo "Installing AgentFlow and msc-thesis packages..."
pip install --no-deps -e "$AGENTFLOW_ROOT/agentflow"
pip install -e .
bash jobs/cosmas_train_pip_reconcile.sh
python -c "import agentflow, agent_engine, fine_tuning, verl, vllm; print('Training imports OK')"

mkdir -p out/fine_tuning

for required_file in \
    data/training/smoke/train/combined_train.parquet \
    data/training/smoke/val/val_search.parquet \
    data/training/smoke/val/val_deepmath.parquet
do
    if [[ ! -f "$required_file" ]]; then
        echo "ERROR: Missing required smoke data file: $required_file"
        echo "Run jobs/008_prepare_fine_tuning_data.job first."
        exit 1
    fi
done

VERL_PID=""
SUBAGENT_PID=""
cleanup() {
    if [[ -n "${VERL_PID:-}" ]] && kill -0 "$VERL_PID" >/dev/null 2>&1; then
        echo "Stopping VERL server (pid=$VERL_PID)..."
        kill "$VERL_PID" || true
        wait "$VERL_PID" || true
    fi
    if [[ -n "${SUBAGENT_PID:-}" ]] && kill -0 "$SUBAGENT_PID" >/dev/null 2>&1; then
        echo "Stopping frozen sub-agent server (pid=$SUBAGENT_PID)..."
        kill "$SUBAGENT_PID" || true
        wait "$SUBAGENT_PID" || true
    fi
}
trap cleanup EXIT

# ── 1. Pre-flight checks (CPU, no VERL needed) ───────────────────────────────
echo ""
echo "Running pre-flight checks..."
python scripts/test_ft_smoke.py \
    --data-dir data/training/smoke \
    --config   experiments/configs/train/config_smoke.yaml

echo ""
echo "Pre-flight checks passed. Starting training..."

# ── 2. Frozen sub-agent vLLM server (separate from VERL, never updated) ──────
echo ""
echo "Starting frozen sub-agent vLLM server (Qwen/Qwen3-1.7B on port 9998)..."
vllm serve Qwen/Qwen3-1.7B \
    --port 9998 \
    --tensor-parallel-size 1 \
    --gpu-memory-utilization 0.15 \
    > out/fine_tuning/smoke_${SLURM_JOB_ID:-local}_subagent.log 2>&1 &
SUBAGENT_PID=$!
export SUBAGENT_ENDPOINT="http://localhost:9998/v1"

echo "Waiting 60s for sub-agent vLLM to be ready..."
sleep 60
if ! kill -0 "$SUBAGENT_PID" >/dev/null 2>&1; then
    echo "FAIL — sub-agent server exited during startup. See out/fine_tuning/smoke_${SLURM_JOB_ID:-local}_subagent.log"
    wait "$SUBAGENT_PID"
fi

# ── 3. VERL server ───────────────────────────────────────────────────────────
echo ""
echo "Starting VERL server (config_smoke.yaml)..."
python scripts/launch_verl.py --config experiments/configs/train/config_smoke.yaml \
    > out/fine_tuning/smoke_${SLURM_JOB_ID:-local}_verl.log 2>&1 &
VERL_PID=$!

echo "Waiting 90s for Ray + vLLM to be ready..."
sleep 90
if ! kill -0 "$VERL_PID" >/dev/null 2>&1; then
    echo "FAIL — VERL server exited during startup. See out/fine_tuning/smoke_${SLURM_JOB_ID:-local}_verl.log"
    wait "$VERL_PID"
fi

# ── 4. Rollout workers ───────────────────────────────────────────────────────
echo ""
echo "Starting rollout workers..."
python scripts/train_orchestrator.py --config experiments/configs/train/config_smoke.yaml

wait $VERL_PID

# ── 5. Verify checkpoint was written ─────────────────────────────────────────
echo ""
echo "Verifying checkpoint..."
CKPT_DIR="experiments/results/training/qwen3-8b-grpo-smoke"
if ls "$CKPT_DIR"/checkpoint_step_*/actor/lora_weights.pt 1>/dev/null 2>&1; then
    echo "PASS — checkpoint found:"
    ls -lh "$CKPT_DIR"/checkpoint_step_*/actor/lora_weights.pt
else
    echo "FAIL — no checkpoint found under $CKPT_DIR"
    exit 1
fi

echo ""
echo "Smoke test complete at: $(date)"
echo "Submit 010_ft_orchestrator.job for the full training run."
