#!/bin/bash
#SBATCH --partition={{ partition }}
#SBATCH --gpus={{ num_gpus }}
#SBATCH --job-name={{ experiment_name }}
#SBATCH --ntasks={{ ntasks }}
#SBATCH --cpus-per-task={{ cpus_per_task }}
#SBATCH --time={{ time }}
#SBATCH --output={{ slurm_output_dir }}/{{ experiment_name }}_%A.log

# Load modules
module purge
module load 2025
module load Miniconda3/25.5.1-1
module load CUDA/12.8.0

# Print info
echo "Job ID: $SLURM_JOB_ID"
echo "Node: $SLURM_NODELIST"
echo "GPUs: $SLURM_GPUS"
echo "Start time: $(date)"

# Set project directory
PROJECT_DIR="{{ project_dir }}"
cd "$PROJECT_DIR" || exit 1

# Activate environment
source activate {{ conda_env }}

# Load API keys and env defaults first so config values can override them
if [ -f ".env" ]; then
    set -a
    # shellcheck disable=SC1091
    source .env
    set +a
fi

# Set reproducibility (must come AFTER .env so config seed wins over any PYTHONHASHSEED in .env)
export PYTHONHASHSEED={{ seed }}
export PYTHONNOUSERSITE=1
export TOKENIZERS_PARALLELISM=false

# Ensure env has required packages (avoid using ~/.local on compute nodes)
python -c "import numpy, torch" 2>/dev/null || { echo "ERROR: numpy/torch not in conda env. Re-run the setup job (001_setup.job) so dependencies are installed into the env."; exit 1; }

# Run experiment
echo "Running experiment: {{ experiment_name }}"
python scripts/run_experiment.py \
  --config {{ config_path }} \
  --output-dir {{ output_dir }}

EXIT_CODE=$?

echo "Exit code: $EXIT_CODE"
echo "End time: $(date)"

exit $EXIT_CODE
