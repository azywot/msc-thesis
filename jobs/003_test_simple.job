#!/bin/bash
#SBATCH --partition=gpu_a100
#SBATCH --gpus=1
#SBATCH --job-name=TestSimpleExample
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --time=00:15:00
#SBATCH --output=out/test/example_subagent_%A.log

set -euo pipefail

echo "=========================================="
echo "MSC Thesis Simple Example Test"
echo "=========================================="
echo "Start time: $(date)"
echo ""

# Load modules
module purge
module load 2025
module load Miniconda3/25.5.1-1
module load CUDA/12.8.0
module load cuDNN/9.10.1.4-CUDA-12.8.0

# Set project directory
PROJECT_DIR="${PROJECT_DIR:-$HOME/azywot/msc-thesis}"
cd "$PROJECT_DIR" || exit 1

echo "Project directory: $PROJECT_DIR"

# Activate environment
ENV_NAME="${ENV_NAME:-agent_engine}"
echo "Activating environment: $ENV_NAME"
source activate "$ENV_NAME"

# Load environment variables from .env
if [ -f ".env" ]; then
    echo "Loading environment variables from .env..."
    set -a
    source <(grep -v '^#' .env | grep -v '^$' | grep -v '^[[:space:]]*#')
    set +a
else
    echo "Warning: .env file not found"
    echo "Make sure SERPER_API_KEY is set"
fi

echo ""
echo "Python version: $(python --version)"
echo "Python path: $(which python)"
echo ""

# Check if SERPER_API_KEY is set
if [ -z "${SERPER_API_KEY:-}" ]; then
    echo "ERROR: SERPER_API_KEY not set"
    echo "Please set it in .env file or export it"
    exit 1
fi

echo "SERPER_API_KEY is set"
echo ""

# Run examples (simple + per-tool sub-agent mode)
echo "=========================================="
echo "Running Examples"
echo "=========================================="
echo ""

FAILURES=()

run_example() {
    local name="$1"
    local cmd="$2"
    echo "------------------------------------------"
    echo "Running: $name"
    echo "Command: $cmd"
    echo "------------------------------------------"
    # With `set -e`, wrap failures so we can continue and collect all failing examples.
    if ! eval "$cmd"; then
        FAILURES+=("$name")
        echo "❌ Failed: $name"
        echo ""
        return 0
    fi
    echo "✅ Passed: $name"
    echo ""
}


# Per-tool (sub-agent mode) examples
run_example "example_code_generator.py" "python examples/example_code_generator.py"
run_example "example_text_inspector.py" "python examples/example_text_inspector.py"
run_example "example_image_inspector.py" "python examples/example_image_inspector.py"
run_example "example_mind_map.py" "python examples/example_mind_map.py"
run_example "example_web_search.py" "python examples/example_web_search.py"

EXIT_CODE=0
if [ ${#FAILURES[@]} -ne 0 ]; then
    EXIT_CODE=1
fi

echo ""
echo "=========================================="
if [ $EXIT_CODE -eq 0 ]; then
    echo "✅ Test PASSED (all examples)"
else
    echo "❌ Test FAILED (some examples failed)"
    echo "Failed examples:"
    for ex in "${FAILURES[@]}"; do
        echo "  - $ex"
    done
fi
echo "=========================================="
echo "End time: $(date)"

exit $EXIT_CODE
