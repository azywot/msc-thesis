#!/bin/bash
#SBATCH --job-name=FTOrchestrator
#SBATCH --partition=gpu_a100
#SBATCH --gpus=4
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --time=24:00:00
#SBATCH --output=out/fine_tuning/ft_%A.log
#SBATCH --error=out/fine_tuning/ft_%A.err

# Full orchestrator fine-tuning run.
#   5 epochs, 100k training questions, n=8 rollouts, thinking enabled.
#   Checkpoint every epoch; best checkpoint symlinked to checkpoint_best/.
#   After training, prune to keep only latest + best checkpoint payloads.
#
# Prerequisites:
#   - Job 008 completed (creates cosmas-train + data/training/)
#   - Job 009 passed    (smoke test verified pipeline is healthy)

set -euo pipefail

echo "=========================================="
echo "MSC Thesis — Orchestrator Fine-Tuning"
echo "=========================================="
echo "Start time: $(date)"
echo "Job ID: ${SLURM_JOB_ID:-local}  Node: $(hostname)"
echo ""

module purge
module load 2025
module load Miniconda3/25.5.1-1
module load CUDA/12.8.0
module load cuDNN/9.10.1.4-CUDA-12.8.0

PROJECT_DIR="${PROJECT_DIR:-$HOME/azywot/msc-thesis}"
cd "$PROJECT_DIR" || exit 1
echo "Project directory: $PROJECT_DIR"

if [[ -f ".env" ]]; then
    echo "Loading environment variables from .env..."
    set -a
    source <(grep -v '^#' .env | grep -v '^$' | grep -v '^[[:space:]]*#')
    set +a
fi

if [[ -z "${SERPER_API_KEY:-}" && -z "${TAVILY_API_KEY:-}" ]]; then
    echo "ERROR: SERPER_API_KEY or TAVILY_API_KEY must be set for rollout workers."
    exit 1
fi

if [[ -z "${WANDB_API_KEY:-}" ]]; then
    echo "Warning: WANDB_API_KEY is not set; W&B logging may fail."
fi

# cosmas-train is created once by jobs/008_prepare_fine_tuning_data.job.
if ! conda env list | awk '{print $1}' | grep -qx "cosmas-train"; then
    echo "ERROR: conda env 'cosmas-train' not found."
    echo "Run jobs/008_prepare_fine_tuning_data.job first (creates env + training data)."
    exit 1
fi

source activate cosmas-train
export PYTHONNOUSERSITE=1

AGENTFLOW_ROOT="${AGENTFLOW_ROOT:-$HOME/azywot/AgentFlow}"
AGENTFLOW_REPO="${AGENTFLOW_REPO:-https://github.com/shin-ee-chen/AgentFlow.git}"
if [[ ! -d "$AGENTFLOW_ROOT/agentflow" ]]; then
    echo "AgentFlow clone not found at $AGENTFLOW_ROOT; cloning..."
    if [[ -e "$AGENTFLOW_ROOT" ]]; then
        echo "ERROR: $AGENTFLOW_ROOT exists but does not contain an agentflow/ package."
        exit 1
    fi
    git clone "$AGENTFLOW_REPO" "$AGENTFLOW_ROOT"
fi

echo "Installing AgentFlow and msc-thesis packages..."
pip install --no-deps -e "$AGENTFLOW_ROOT/agentflow"
pip install -e .
bash jobs/cosmas_train_pip_reconcile.sh
python -c "import agentflow, agent_engine, fine_tuning, verl, vllm; print('Training imports OK')"

mkdir -p out/fine_tuning

for required_file in \
    data/training/train/combined_train.parquet \
    data/training/val/val_search.parquet \
    data/training/val/val_deepmath.parquet
do
    if [[ ! -f "$required_file" ]]; then
        echo "ERROR: Missing required training data file: $required_file"
        echo "Run jobs/008_prepare_fine_tuning_data.job first."
        exit 1
    fi
done

VERL_PID=""
cleanup() {
    if [[ -n "${VERL_PID:-}" ]] && kill -0 "$VERL_PID" >/dev/null 2>&1; then
        echo "Stopping VERL server (pid=$VERL_PID)..."
        kill "$VERL_PID" || true
        wait "$VERL_PID" || true
    fi
}
trap cleanup EXIT

# ── 1. VERL server ───────────────────────────────────────────────────────────
echo ""
echo "Starting VERL server..."
python scripts/launch_verl.py --config train/config.yaml \
    > out/fine_tuning/ft_${SLURM_JOB_ID:-local}_verl.log 2>&1 &
VERL_PID=$!

echo "Waiting 120s for Ray + vLLM to be ready..."
sleep 120
if ! kill -0 "$VERL_PID" >/dev/null 2>&1; then
    echo "FAIL — VERL server exited during startup. See out/fine_tuning/ft_${SLURM_JOB_ID:-local}_verl.log"
    wait "$VERL_PID"
fi

# ── 2. Rollout workers ───────────────────────────────────────────────────────
echo ""
echo "Starting rollout workers..."
python scripts/train_orchestrator.py --config train/config.yaml

wait $VERL_PID

# ── 3. Verify checkpoint ─────────────────────────────────────────────────────
echo ""
EXPERIMENT_NAME="qwen3-8b-grpo-search-math"
CKPT_DIR="experiments/results/training/${EXPERIMENT_NAME}"
echo "Checkpoints written to: $CKPT_DIR"
ls -lh "$CKPT_DIR"/checkpoint_*/actor/lora_weights.pt 2>/dev/null || echo "No checkpoints found."

# ── 4. Prune checkpoints (keep latest + best) ────────────────────────────────
echo ""
echo "Pruning checkpoints: keeping latest and best..."

mapfile -t STEP_DIRS < <(compgen -G "$CKPT_DIR/checkpoint_step_*" || true)
if ((${#STEP_DIRS[@]} == 0)); then
    echo "No step checkpoints found; skipping prune."
else
    LATEST_STEP_DIR="$(printf '%s\n' "${STEP_DIRS[@]}" | sort -V | tail -n 1)"
    BEST_TARGET="$(readlink -f "$CKPT_DIR/checkpoint_best" 2>/dev/null || true)"

    echo "Latest checkpoint: $LATEST_STEP_DIR"
    if [[ -n "$BEST_TARGET" ]]; then
        echo "Best checkpoint target: $BEST_TARGET"
    else
        echo "Best checkpoint target not resolved; will keep latest only."
    fi

    for d in "${STEP_DIRS[@]}"; do
        KEEP=0
        [[ "$d" == "$LATEST_STEP_DIR" ]] && KEEP=1
        [[ -n "$BEST_TARGET" && "$d" == "$BEST_TARGET" ]] && KEEP=1
        if ((KEEP == 0)); then
            echo "Removing old checkpoint: $d"
            rm -rf "$d"
        fi
    done
fi

echo "Remaining checkpoint payloads:"
ls -lh "$CKPT_DIR"/checkpoint_*/actor/lora_weights.pt 2>/dev/null || echo "No checkpoints found."

echo ""
echo "Training complete at: $(date)"
echo ""
echo "Next step — merge LoRA and evaluate:"
echo "  python \$HOME/azywot/AgentFlow/util/model_merger.py \\"
echo "    --base_model Qwen/Qwen3-8B \\"
echo "    --lora_path $CKPT_DIR/checkpoint_best/actor/lora_weights.pt \\"
echo "    --output_dir $CKPT_DIR/merged_model/"
